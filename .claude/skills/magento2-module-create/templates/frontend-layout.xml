<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
      layout="1column">
    <body>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="{vendor_lower}_{module_lower}.{route}.{action}"
                   template="{Vendor}_{ModuleName}::{name}.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">{Vendor}\{ModuleName}\ViewModel\{Name}ViewModel</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
