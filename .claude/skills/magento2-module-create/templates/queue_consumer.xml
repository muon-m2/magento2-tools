<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework-message-queue:etc/consumer.xsd">
    <consumer name="{vendor_lower}.{module_lower}.{consumer_description}"
              queue="{vendor_lower}.{module_lower}.{queue_name}"
              connection="amqp"
              consumerInstance="Magento\Framework\MessageQueue\Consumer"
              handler="{Vendor}\{ModuleName}\Model\Consumer\{ConsumerName}::process"
              maxMessages="100"/>
</config>
