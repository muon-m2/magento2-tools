<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="acme" translate="label"><label>Acme</label></tab>
        <section id="acme_sample" translate="label" showInDefault="1">
            <label>Sample</label><tab>acme</tab>
            <group id="general" translate="label" showInDefault="1">
                <label>General</label>
                <field id="enabled" translate="label comment" type="select" showInDefault="1">
                    <label>Enabled</label><comment>Turns the feature on.</comment>
                </field>
            </group>
        </section>
    </system>
</config>
