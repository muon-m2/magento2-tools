<?xml version="1.0"?>
<!--
  ACL resource for {Vendor}_{Module} store configuration.
  Target: {Vendor}/{Module}/etc/acl.xml  (MERGE into existing acl.xml; do not clobber)

  The config resource is referenced by the <resource> element inside system.xml's <section>.
  It nests under Magento_Config::config so that it appears in the Stores → Configuration
  ACL section. If you also want granting {Vendor}_{Module}::main to imply config access,
  additionally declare this resource as a child of {Vendor}_{Module}::main in the same file.

  acl.xsd allows ONLY id, title, sortOrder, disabled on <resource>. Do NOT add
  translate="..." — that attribute belongs on menu.xml <add>, not here.
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Config::config">
                    <resource id="{Vendor}_{Module}::config" title="{Title} Configuration"
                              sortOrder="10"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
