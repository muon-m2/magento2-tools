<?xml version="1.0"?>
<!--
    Preference wiring for {Vendor}_{Module}.
    Target: {Vendor}/{Module}/etc/{area}/di.xml  (merge into existing file)

    Tokens: {PreferenceFor}, {Vendor}, {Module}, {EntityName}
    Adjust {area}/ prefix: omit for global, or use frontend/ adminhtml/ webapi_rest/ etc.

    NOTE: two modules preferring the same interface conflict — only one wins per area.
    Use a plugin on the concrete class whenever possible to avoid conflicts.
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="{PreferenceFor}"
                type="{Vendor}\{Module}\Model\{EntityName}"/>
</config>
