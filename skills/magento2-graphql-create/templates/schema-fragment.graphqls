# {Vendor}_{Module} GraphQL Schema Fragment

type Query {
    {vendor_lower}{Entity}(id: ID! @doc(description: "Entity ID")): {Entity} @resolver(class: "\\{Vendor}\\{Module}\\Model\\Resolver\\Get{Entity}") @doc(description: "Fetch a single {Entity} by ID")

    {vendor_lower}{Entity}List(
        filter: {Entity}FilterInput
        currentPage: Int = 1
        pageSize: Int = 20
    ): {Entity}Listing @resolver(class: "\\{Vendor}\\{Module}\\Model\\Resolver\\List{Entity}") @doc(description: "List {Entity} entities with pagination")
}

type Mutation {
    {vendor_lower}Create{Entity}(input: {Entity}CreateInput!): {Entity}! @resolver(class: "\\{Vendor}\\{Module}\\Model\\Resolver\\Create{Entity}") @doc(description: "Create a new {Entity}")
}

type {Entity} {
    id: ID!
    name: String!
    status: {Entity}Status!
    created_at: String!
}

type {Entity}Listing {
    items: [{Entity}]!
    total_count: Int!
    page_info: SearchResultPageInfo!
}

enum {Entity}Status {
    PENDING
    APPROVED
    REJECTED
}

input {Entity}FilterInput {
    name: String
    status: {Entity}Status
}

input {Entity}CreateInput {
    name: String!
    status: {Entity}Status
}
