# Runtime cache (regenerated per project by magento2-context, keyed by composer.lock hash)
.claude/.cache/
.cache/

# Local Claude Code workflow scripts — not part of the shipped plugin
.claude/workflows/

# Scratch / temp artifacts copied in for local review — never shipped
.tmp/

# Local, machine-specific settings — never share
*.local.json
.claude/settings.local.json

# IDE
.idea/
.vscode/

# OS noise
.DS_Store

# Stale manual packages superseded by this repo
skills.zip

# Internal audit / process docs — kept local, not part of the shipped plugin.
# The CHANGELOG is the durable record of what changed.
SKILLS-ANALYSIS-REPORT.md
SKILLS-IMPROVEMENT-PLAN.md
SKILLS-REMEDIATION-REPORT.md
